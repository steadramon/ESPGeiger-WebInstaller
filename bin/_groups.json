{
  "_comment": "Source of truth for which envs go in which webinstaller group. The sync_release.py script regenerates each manifest.json from this plus the offsets.json embedded in the release's webinstall zip.",
  "groups": [
    {
      "path": "pulse",
      "name": "ESPGeiger Pulse {version}",
      "envs": {
        "ESP32":    "esp32_pulse_no_pcnt",
        "ESP32-S3": "esp32s3_pulse_no_pcnt",
        "ESP32-C3": "esp32c3_pulse",
        "ESP8266":  "esp8266_pulse"
      }
    },
    {
      "path": "pulse/oled",
      "name": "ESPGeiger OLED Pulse {version}",
      "envs": {
        "ESP32":    "esp32oled_pulse_no_pcnt",
        "ESP32-S3": "esp32s3oled_pulse_no_pcnt",
        "ESP8266":  "esp8266oled_pulse"
      }
    },
    {
      "path": "pulse_pcnt",
      "name": "ESPGeiger Pulse PCNT {version}",
      "envs": {
        "ESP32":    "esp32_pulse",
        "ESP32-S3": "esp32s3_pulse"
      }
    },
    {
      "path": "pulse_pcnt/oled",
      "name": "ESPGeiger OLED Pulse PCNT {version}",
      "envs": {
        "ESP32":    "esp32oled_pulse",
        "ESP32-S3": "esp32s3oled_pulse"
      }
    },
    {
      "path": "serial",
      "name": "ESPGeiger Serial {version}",
      "envs": {
        "ESP32":    "esp32_serial",
        "ESP32-S3": "esp32s3_serial",
        "ESP32-C3": "esp32c3_serial",
        "ESP8266":  "esp8266_serial"
      }
    },
    {
      "path": "serial/oled",
      "name": "ESPGeiger OLED Serial {version}",
      "envs": {
        "ESP32":    "esp32oled_serial",
        "ESP32-S3": "esp32s3oled_serial",
        "ESP8266":  "esp8266oled_serial"
      }
    },
    {
      "path": "test",
      "name": "ESPGeiger Test {version}",
      "envs": {
        "ESP32":   "esp32_test",
        "ESP8266": "esp8266_test"
      }
    },
    {
      "path": "test/oled",
      "name": "ESPGeiger OLED Test {version}",
      "envs": {
        "ESP32":   "esp32oled_test",
        "ESP8266": "esp8266oled_test"
      }
    },
    {
      "path": "test_pulse",
      "name": "ESPGeiger Test Pulse {version}",
      "envs": {
        "ESP32":   "esp32_testpulse",
        "ESP8266": "esp8266_testpulse"
      }
    },
    {
      "path": "test_pulse/oled",
      "name": "ESPGeiger OLED Test Pulse {version}",
      "envs": {
        "ESP32":   "esp32oled_testpulse",
        "ESP8266": "esp8266oled_testpulse"
      }
    },
    {
      "path": "cajoeiot",
      "name": "ESPGeiger Cajoe IOT {version}",
      "envs": {
        "ESP32": "esp32_cajoe_iotgm"
      }
    },
    {
      "path": "espgeigerlog",
      "name": "ESPGeiger-Log {version}",
      "envs": {
        "ESP8266": "espgeigerlog"
      }
    },
    {
      "path": "espgeigerlog_serial",
      "name": "ESPGeiger-Log Serial {version}",
      "envs": {
        "ESP8266": "espgeigerlog_serial"
      }
    },
    {
      "path": "espgeigerlog_test",
      "name": "ESPGeiger-Log Test {version}",
      "envs": {
        "ESP8266": "espgeigerlog_test"
      }
    },
    {
      "path": "espgeigerhw",
      "name": "ESPGeiger-HW {version}",
      "envs": {
        "ESP8266": "espgeigerhw"
      }
    }
  ]
}
